      "name": "Thing",
      "parents": [],
      "comment": "The root class for all entities.",
      "disjoint_with": []
    },
    {
      "name": "Agent",
      "parents": [
        "Thing"
      ],
      "comment": "An entity capable of action in the retail domain.",
