{
  "ontology_name": "retail-ontology",
  "iri_base": "https://example.org/retail/",
  "prefix": "retail",
  "description": "An ontology for modeling the retail domain, including stores, products, customers, employees, sales, and inventory.",
  "classes": [
    {
      "name": "Entity",
      "parents": [],
      "comment": "Top-level class for all entities in the retail domain.",
      "disjoint_with": []
    },
    {
      "name": "Person",
      "parents": [
        "Entity"
      ],
      "comment": "A human involved in the retail domain.",
      "disjoint_with": []
    },
    {
      "name": "Customer",
      "parents": [
        "Person"
      ],
      "comment": "A person who purchases products.",
      "disjoint_with": [
        "Employee"
      ]
    },
    {
      "name": "Employee",
      "parents": [
        "Person"
      ],
      "comment": "A person who works at a store.",
      "disjoint_with": [
        "Customer"
      ]
    },
    {
      "name": "Cashier",
      "parents": [
        "Employee"
      ],
      "comment": "An employee who handles sales transactions.",
      "disjoint_with": []
    },
    {
      "name": "Manager",
      "parents": [
        "Employee"
      ],
      "comment": "An employee who manages a store.",
      "disjoint_with": []
    },
    {
      "name": "Store",
      "parents": [
        "Entity"
      ],
      "comment": "A physical or online location where products are sold.",
      "disjoint_with": []
    },
    {
      "name": "Product",
      "parents": [
        "Entity"
      ],
      "comment": "An item available for sale.",
      "disjoint_with": []
    },
    {
      "name": "Category",
      "parents": [
        "Entity"
      ],
      "comment": "A classification for products.",
      "disjoint_with": []
    },
    {
      "name": "InventoryItem",
      "parents": [
        "Entity"
      ],
      "comment": "A specific stock of a product in a store.",
      "disjoint_with": []
    },
    {
      "name": "Sale",
      "parents": [
        "Entity"
      ],
      "comment": "A transaction where a customer purchases products.",
      "disjoint_with": []
    },
    {
      "name": "Payment",
      "parents": [
        "Entity"
      ],
      "comment": "A payment made for a sale.",
      "disjoint_with": []
    }
  ],
  "object_properties": [
    {
      "name": "purchasedBy",
      "domain": "Sale",
      "range": "Customer",
      "inverse_of": "madePurchase",
      "transitive": false,
      "symmetric": false,
      "functional": false,
      "comment": "Links a sale to the customer who made the purchase."
    },
    {
      "name": "madePurchase",
      "domain": "Customer",
      "range": "Sale",
      "inverse_of": "purchasedBy",
      "transitive": false,
      "symmetric": false,
      "functional": false,
      "comment": "Links a customer to sales they made."
    },
    {
      "name": "soldBy",
      "domain": "Sale",
      "range": "Cashier",
      "inverse_of": "handledSale",
      "transitive": false,
      "symmetric": false,
      "functional": false,
      "comment": "Links a sale to the cashier who handled it."
    },
    {
      "name": "handledSale",
      "domain": "Cashier",
      "range": "Sale",
      "inverse_of": "soldBy",
      "transitive": false,
      "symmetric": false,
      "functional": false,
      "comment": "Links a cashier to sales they handled."
    },
    {
      "name": "occursAt",
      "domain": "Sale",
      "range": "Store",
      "inverse_of": "hasSale",
      "transitive": false,
      "symmetric": false,
      "functional": false,
      "comment": "Links a sale to the store where it occurred."
