      "range": "Store",
      "inverse_of": "hasInventoryItem",
      "transitive": false,
      "symmetric": false,
      "functional": false,
      "comment": "Links an inventory item to the store where it is stocked."
    },
    {
      "name": "ofProduct",
      "domain": "InventoryItem",
      "range": "Product",
      "inverse_of": "hasInventoryItemOf",
      "transitive": false,
      "symmetric": false,
      "functional": false,
      "comment": "Links an inventory item to the product it represents."
    },
    {
      "name": "hasInventoryItemOf",
      "domain": "Product",
      "range": "InventoryItem",
      "inverse_of": "ofProduct",
      "transitive": false,
      "symmetric": false,
      "functional": false,
      "comment": "Links a product to its inventory items."
    },
    {
      "name": "belongsToCategory",
      "domain": "Product",
      "range": "Category",
      "inverse_of": "hasProduct",
      "transitive": false,
      "symmetric": false,
      "functional": false,
      "comment": "Links a product to its category."
    },
    {
      "name": "hasProduct",
      "domain": "Category",
      "range": "Product",
      "inverse_of": "belongsToCategory",
      "transitive": false,
      "symmetric": false,
      "functional": false,
      "comment": "Links a category to its products."
    },
    {
      "name": "includesProduct",
      "domain": "Sale",
      "range": "Product",
      "inverse_of": null,
      "transitive": false,
      "symmetric": false,
      "functional": false,
      "comment": "Links a sale to products sold."
    },
    {
      "name": "hasPayment",
      "domain": "Sale",
      "range": "Payment",
      "inverse_of": "paymentFor",
      "transitive": false,
      "symmetric": false,
      "functional": false,
      "comment": "Links a sale to its payment."
    },
    {
      "name": "paymentFor",
      "domain": "Payment",
      "range": "Sale",
      "inverse_of": "hasPayment",
      "transitive": false,
      "symmetric": false,
      "functional": false,
      "comment": "Links a payment to the sale it is for."
    }
