{
  "ontology_name": "chip-supplychain",
  "iri_base": "https://example.org/chip-supplychain/",
  "prefix": "chipsc",
  "description": "An ontology modeling the manufacturing supply chain for chip fabrication, including organizations, facilities, materials, equipment, processes, products, shipments, and personnel.",
