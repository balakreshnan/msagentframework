{
  "ontology_name": "retail-core",
  "iri_base": "https://example.org/retail/",
  "prefix": "retail",
  "description": "A core ontology for the retail domain, covering stores, products, customers, employees, transactions, and inventory.",
  "classes": [
    {
      "name": "Agent",
      "parents": [],
      "comment": "A general entity capable of action in the retail domain.",
      "disjoint_with": []
    },
    {
      "name": "Person",
      "parents": [
        "Agent"
      ],
      "comment": "A human agent in the retail domain.",
      "disjoint_with": []
    },
    {
      "name": "Customer",
      "parents": [
        "Person"
      ],
      "comment": "A person who purchases products from a store.",
      "disjoint_with": [
        "Employee"
      ]
    },
    {
      "name": "Employee",
      "parents": [
        "Person"
      ],
      "comment": "A person employed by a store.",
      "disjoint_with": [
        "Customer"
      ]
    },
    {
      "name": "Cashier",
      "parents": [
        "Employee"
      ],
      "comment": "An employee who handles sales transactions.",
      "disjoint_with": []
    },
    {
      "name": "Manager",
