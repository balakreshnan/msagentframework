        "Employee"
      ],
      "comment": "An employee who manages a store.",
      "disjoint_with": []
    },
    {
      "name": "Store",
      "parents": [],
      "comment": "A physical or online retail location.",
      "disjoint_with": []
    },
    {
      "name": "Product",
      "parents": [],
      "comment": "An item available for sale in a store.",
      "disjoint_with": []
    },
    {
      "name": "Category",
      "parents": [],
      "comment": "A classification for products.",
      "disjoint_with": []
    },
    {
      "name": "Transaction",
      "parents": [],
      "comment": "A record of a sale between a customer and a store.",
      "disjoint_with": []
    },
    {
      "name": "InventoryItem",
      "parents": [],
      "comment": "A specific stock of a product at a store.",
      "disjoint_with": []
    },
    {
      "name": "Promotion",
      "parents": [],
      "comment": "A special offer or discount on products.",
      "disjoint_with": []
    }
  ],
  "object_properties": [
